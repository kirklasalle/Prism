# =============================================================================
# PRISM Environment Configuration — Example
# =============================================================================
# Copy this file to `.env` (workspace root) or to `${PRISM_WORKSPACE_ROOT}/.env`
# and fill in the values that apply to your deployment. Never commit a populated
# `.env` to source control.
#
# Variable scopes:
#   [P] = MANDATORY in production (NODE_ENV=production)
#   [R] = Recommended (silent default if unset; explicit value preferred)
#   [O] = Optional (feature gating, OAuth, or provider keys)
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime profile
# -----------------------------------------------------------------------------
# [P] Required for production startup checks (PRISM refuses to boot in prod
#     without a strong PRISM_JWT_SECRET when NODE_ENV=production).
NODE_ENV=development

# [R] dev | staging | prod — controls retrieval alert thresholds, log verbosity,
#     and CI gating defaults. CI sets `staging` automatically.
PRISM_ENV_PROFILE=dev

# [R] server | tui | cli — selects entrypoint. `server` runs the Express +
#     WebSocket dashboard on PRISM_DASHBOARD_PORT.
PRISM_MODE=server

# [R] business | individual — picks the execution profile envelope used for
#     policy tier defaults, capability surface, and Setup Wizard branching.
PRISM_EXECUTION_PROFILE=individual

# -----------------------------------------------------------------------------
# Workspace paths
# -----------------------------------------------------------------------------
# [P] Absolute path to a writable directory. Required in production so SQLite
#     databases, characters, plugin packs, and audit logs are persistent across
#     container restarts. If unset, PRISM uses an OS-default per workspace-resolver.
PRISM_DATA_DIR=

# [O] Override for legacy CWD-relative resolution. Prefer PRISM_DATA_DIR.
PRISM_WORKSPACE_ROOT=

# [O] Path to a custom MCP settings file. Defaults to
#     ${PRISM_DATA_DIR}/config/mcp-settings.json or ./.mcp/mcp-settings.json.
PRISM_MCP_SETTINGS=

# -----------------------------------------------------------------------------
# Dashboard transport & security
# -----------------------------------------------------------------------------
# [R] HTTP port for the dashboard + Approval Queue API.
PRISM_DASHBOARD_PORT=7070

# [P] Cryptographic secret used to sign session/auth tokens. MUST be at least
#     32 characters in production. Generate one via:
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRISM_JWT_SECRET=

# [O] Optional TLS for the dashboard. If both are set, PRISM serves over HTTPS.
PRISM_TLS_CERT=
PRISM_TLS_KEY=

# [P] Must be `false` in production. Setting `true` disables auth on every
#     dashboard route — only valid for local development.
PRISM_AUTH_DISABLED=false

# [R] Per-token / per-IP rate limit (requests per minute) on the dashboard
#     HTTP surface. R2 (2026-Q3) adds tighter per-route caps that apply
#     ON TOP of this global cap:
#       • /api/auth/*       — 20 req/min  (brute-force defense)
#       • /api/setup/*      — 30 req/min  (first-run mutation surface)
#       • /api/chat/stream  — 60 req/min  (LLM provider quota guard)
#     Production deployments should pin the global cap to a value ≤ 60.
PRISM_RATE_LIMIT=200

# [R] Maximum body size in bytes accepted by the dashboard service. Defaults
#     to 10 MiB.
PRISM_MAX_BODY_SIZE=10485760

# [R] Comma-separated CORS origin allowlist (R2). The dashboard's own
#     loopback origins (http://localhost:PORT, http://127.0.0.1:PORT, and
#     their https:// variants) are auto-included; this variable adds
#     additional origins (e.g. an operator-only admin host). Wildcards
#     ("*") are rejected at startup. Each entry must be a full origin —
#     `scheme://host[:port]`, no path.
PRISM_CORS_ORIGINS=

# [R] Set to "true" to suppress the per-rejection WARN log emitted by the
#     CORS / CSRF guard. Useful in noisy environments where many probes
#     are expected. Defense itself is unaffected.
PRISM_SECURITY_QUIET=

# -----------------------------------------------------------------------------
# Logging & observability
# -----------------------------------------------------------------------------
# [R] json | text — `json` is recommended for any aggregated logging pipeline.
PRISM_LOG_FORMAT=text

# [O] Override for the log directory. Default is ${PRISM_DATA_DIR}/logs.
PRISM_LOG_DIR=

# [O] Enable OpenTelemetry OTLP exporter. Set the endpoint URL to enable.
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Optional feature dependencies
# -----------------------------------------------------------------------------
# These optional npm dependencies activate real I/O paths when installed:
#   - node-pty            → real PTY in TerminalSessionAdapter
#   - dockerode           → real Docker daemon in ContainerSandboxAdapter
#   - googleapis          → real Gmail/Calendar in GmailOAuthAdapter
#   - @azure/msal-node    → real Outlook in OutlookOAuthAdapter
#
# When these are missing, the adapters fall back to a deny-by-default safe path
# and surface a warning on /api/health under `dependencies`.

# -----------------------------------------------------------------------------
# LLM provider keys (set only the providers you use)
# -----------------------------------------------------------------------------
PRISM_LLM_PROVIDER=ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
COHERE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# OAuth canary credentials (PTAC live scenarios + nightly E2E)
# -----------------------------------------------------------------------------
# Used only by `npm run ptac:host -- --scenario=s08-gmail-canary` and the
# nightly OAuth integration suite. Leave blank in normal operation.
PRISM_CANARY_GMAIL_CLIENT_ID=
PRISM_CANARY_GMAIL_CLIENT_SECRET=
PRISM_CANARY_GMAIL_REFRESH_TOKEN=
PRISM_CANARY_OUTLOOK_CLIENT_ID=
PRISM_CANARY_OUTLOOK_CLIENT_SECRET=
PRISM_CANARY_OUTLOOK_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# PTAC (Prism Testing & Active Control)
# -----------------------------------------------------------------------------
# [R] sandbox | host — selects the PTAC execution profile.
#     sandbox = isolated VM/container; host = operator desktop with kill-switch.
PRISM_PTAC_PROFILE=sandbox

# [R] Output directory for PTAC run artifacts (screenshots, action logs, video,
#     report.html). Defaults to ${PRISM_DATA_DIR}/ptac.
PRISM_PTAC_OUTPUT_DIR=

# [R] Global panic chord for PTAC host profile. Aborts the active run within
#     ~200 ms and emits an audit event. Default: Ctrl+Alt+Shift+Escape.
PRISM_PTAC_PANIC_CHORD=ctrl+alt+shift+escape

# [R] Idle watchdog timeout (seconds). PTAC host profile aborts if the operator
#     window loses focus for longer than this. Default: 60.
PRISM_PTAC_IDLE_TIMEOUT_S=60

# -----------------------------------------------------------------------------
# Phase E — Multi-tenant scoping (opt-in)
# -----------------------------------------------------------------------------
# [O] Enables tenant-scoped subroots under {workspace}/.tenants/{id}/. When OFF
#     (default), all behavior is single-tenant identical to legacy. When ON,
#     a request carrying X-Prism-Tenant: <id> runs against that tenant's
#     filesystem subroot. Id pattern: ^[a-z0-9][a-z0-9_-]{0,63}$.
PRISM_MULTI_TENANT=

# -----------------------------------------------------------------------------
# Phase F/G — Compatibility surfaces (informative)
# -----------------------------------------------------------------------------
# The OpenAI Assistants API compatibility shim is mounted at /v1/* on the
# dashboard whenever the dashboard is running. It is gated by the same bearer
# token as every other dashboard route (no separate flag, no separate token).
# Existing OpenAI Python/Node clients reach PRISM by setting:
#   base_url = http://<host>:${PRISM_DASHBOARD_PORT}/v1
#   api_key  = <PRISM admin token>
#
# The Python SDK (`sdk/python/prism-client`) reads two env vars on the
# CLIENT side (not server-side; documented here for completeness):
#   PRISM_BASE_URL   — dashboard base URL (e.g. http://localhost:7070)
#   PRISM_TOKEN      — admin bearer token

# -----------------------------------------------------------------------------
# Phase H — Enterprise IAM (opt-in)
# -----------------------------------------------------------------------------
# [O] Master switch for the enterprise IAM layer. When OFF (default), the
#     legacy single-admin-token path is the only auth gate and none of the
#     /api/iam/* routes are mounted. When ON, the dashboard registers SSO
#     routes and accepts session cookies / API keys in addition to the
#     admin token.
PRISM_ENTERPRISE_IAM=

# [P] HMAC secret for the SSO session cookie. Required (>=32 chars) in
#     production when PRISM_ENTERPRISE_IAM=on. If unset in dev, a random
#     in-memory value is used and existing sessions are invalidated on
#     every restart.
PRISM_SSO_SESSION_SECRET=

# [Q] When set to "on" (and PRISM_ENTERPRISE_IAM=on), mounts the SCIM 2.0
#     endpoints under /scim/v2/* for IdP-driven user provisioning. Tokens
#     are issued via the IAM admin UI (/public/iam-admin.html) and are
#     verified per-request against the iam_scim_tokens table.
PRISM_SCIM=

# -----------------------------------------------------------------------------
# Phase SOC2 — SOC 2 evidence exporter (opt-in)
# -----------------------------------------------------------------------------
# [R] Mode: off | file | webhook. Default off. When file, every SOC 2-classified
#     ActivityBus event is written as JSONL under prism-output/soc2/YYYY-MM-DD.jsonl.
#     When webhook, batched POSTs are sent to PRISM_SOC2_WEBHOOK_URL; failures
#     fall back to prism-output/soc2/_dlq.jsonl so no evidence is lost.
PRISM_SOC2_EXPORTER=

# [S] Destination URL for the webhook transport (https recommended).
PRISM_SOC2_WEBHOOK_URL=

# [T] Bearer token surfaced as `Authorization: Bearer <token>` on each POST.
PRISM_SOC2_WEBHOOK_TOKEN=

# [U] Vendor flavor: generic | vanta | drata. Controls the JSON envelope
#     shape so the same exporter feeds either Vanta or Drata directly.
PRISM_SOC2_WEBHOOK_FLAVOR=
