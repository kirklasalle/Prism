{
    "root": true,
    "env": {
        "node": true,
        "es2022": true
    },
    "extends": [
        "eslint:recommended"
    ],
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_"
            }
        ],
        "no-console": "off",
        "prefer-const": "warn",
        "no-var": "error",
        "eqeqeq": [
            "error",
            "always"
        ],
        "curly": [
            "warn",
            "multi-line"
        ],
        "no-throw-literal": "warn"
    },
    "ignorePatterns": [
        "dist/",
        "node_modules/",
        "*.js",
        "*.d.ts",
        "*.js.map"
    ]
}