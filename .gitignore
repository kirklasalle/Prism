# ── Compiled artifacts in src/ — must NEVER be committed ──────────────
src/**/*.js
src/**/*.d.ts
src/**/*.js.map

# Build artifacts
node_modules/
dist/
*.log
prism-output/
tmp/
.venv/
.prism-preferences.json
models/
*.gguf
screengrab/
*.db.sq
*.db.sq2
*.db
*.db-shm
*.db-wal

# Test output files
test_out.txt
test_output*.txt
test_output*.log

# Scratch / debug scripts — developer-only, never commit
scratch*
scratch-*

# Python bytecode — never commit
__pycache__/
*.pyc
*.pyo

# Local environment & secrets — never commit
.env
.env.*
!.env.example

# Plugin signing private keys — must be stored in operator-controlled secret manager
config/plugin-private-key*.pem
*.priv.pem
