{
  "name": "impressioncore-vrgc",
  "version": "1.0.0",
  "description": "Virtually Robotic GitHub Copilot MCP Server for ImpressionCore",
  "type": "mcp-server",
  "main": "server.py",
  "author": "GitHub Copilot (VRGC)",
  "created": "2025-06-16",
  "license": "MIT",
  "keywords": [
    "mcp",
    "copilot", 
    "ai",
    "impressioncore",
    "virtual-robot",
    "autonomous"
  ],
  "capabilities": {
    "tools": [
      {
        "name": "vrgc_system_assessment",
        "description": "Comprehensive ImpressionCore system assessment",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_training_monitor",
        "description": "Monitor B1 training progress and performance",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_training_status",
        "description": "Get current B1 training status and metrics",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_hardware_assessment",
        "description": "Assess GTX 1050 Ti hardware state",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_hardware_optimize",
        "description": "Optimize hardware for ImpressionCore-B1 training",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_performance_monitor",
        "description": "Monitor hardware performance during training",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_covenant_verify",
        "description": "Verify Sacred Covenant file integrity",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_covenant_backup",
        "description": "Create comprehensive Sacred Covenant backup",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_covenant_monitor",
        "description": "Monitor Sacred Covenant compliance",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_project_analysis",
        "description": "Comprehensive project intelligence analysis",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_complexity_analysis",
        "description": "Analyze code complexity across the project",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_velocity_analysis",
        "description": "Analyze development velocity and patterns",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_optimization_analysis",
        "description": "Identify optimization opportunities",
        "standalone": true,
        "ids_enhanced": true
      },
      {
        "name": "vrgc_status",
        "description": "Get comprehensive VRGC system status",
        "standalone": true,
        "ids_enhanced": false
      },
      {
        "name": "vrgc_robotic_mode",
        "description": "Execute full Virtually Robotic Copilot sequence",
        "standalone": true,
        "ids_enhanced": true
      }
    ],
    "integrations": {
      "impressioncore-ids": {
        "type": "optional",
        "description": "Enhanced context through IDS documentation system",
        "fallback": "standalone_mode"
      }
    }
  },
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      "psutil",
      "GPUtil", 
      "torch",
      "numpy"
    ],
    "optional_dependencies": [
      "mcp"
    ]
  },
  "configuration": {
    "default_ids_integration": true,
    "fallback_mode": "standalone",
    "monitoring_intervals": {
      "training_monitor_default_minutes": 10,
      "performance_monitor_default_minutes": 5
    }
  },
  "sacred_covenant_compliance": {
    "file_integrity_protected": true,
    "backup_system_integrated": true,
    "professional_standards_enforced": true,
    "covenant_guardian_active": true
  }
}
