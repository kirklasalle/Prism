{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus instance scraping the PRISM dashboard /metrics endpoint.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "PRISM Operator Dashboard — starter Grafana panels backed by the /metrics Prometheus exposition. Pairs with src/core/activity/metrics-store.ts and src/core/activity/otel-exporter.ts. Closes R6 / E6-7.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Sessions",
      "description": "Live chat sessions currently tracked by the operator dashboard.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "prism_active_sessions", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending Approvals",
      "description": "Depth of the Approval Queue (Tier-2/Tier-3 work awaiting human decision).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "prism_approval_queue_depth", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 25 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Uptime",
      "description": "Seconds since the dashboard process started.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "prism_uptime_seconds", "refId": "A" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "PRISM Build",
      "description": "service+version label from the prism_info gauge.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "prism_info", "refId": "A", "format": "table", "instant": true }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "colorMode": "none", "graphMode": "none", "textMode": "name", "justifyMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Activity events / sec by status",
      "description": "Rate of ActivityBus events broken down by status (succeeded / failed / etc). Drives the live operator feed.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(prism_activity_events_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors / sec by layer",
      "description": "Failed-event rate split by subsystem. A spike here is the top-line health alarm.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (layer) (rate(prism_errors_total[5m]))",
          "legendFormat": "{{layer}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Operation duration p50 / p95 / p99 (ms)",
      "description": "End-to-end latency of all instrumented PRISM operations. Sourced from prism_operation_duration_ms histogram.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(prism_operation_duration_ms_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(prism_operation_duration_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(prism_operation_duration_ms_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "LLM latency p50 / p95 (ms)",
      "description": "Per-request LLM generation latency from prism_llm_latency_ms histogram. Spikes here are typically provider-side.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(prism_llm_latency_ms_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(prism_llm_latency_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Policy decisions / sec by tier and outcome",
      "description": "Breakdown of policy gate decisions. allow / deny / approval_required mapped from authorityTier × policyDecision.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (tier, decision) (rate(prism_policy_decisions_total[5m]))",
          "legendFormat": "{{tier}} / {{decision}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Tool executions / sec by status",
      "description": "Tool execution attempts (success vs failure) — wires straight to the Tools tab.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(prism_tool_executions_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Governance hooks / sec by decision",
      "description": "PreToolUse/PostToolUse hook evaluations grouped by permission_decision. Use this to spot governance regressions immediately.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (hook, decision) (rate(prism_governance_hooks_total[5m]))",
          "legendFormat": "{{hook}} / {{decision}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Agent lifecycle events / sec",
      "description": "Spawn / pause / resume / terminate transitions across agents. A flat zero line means no agents are active.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (operation) (rate(prism_agent_lifecycle_total[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["prism", "observability", "r6"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "PRISM — Operator Dashboard",
  "uid": "prism-operator",
  "version": 1,
  "weekStart": ""
}
