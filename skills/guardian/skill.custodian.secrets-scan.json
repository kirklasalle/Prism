{
    "id": "skill.custodian.secrets-scan",
    "version": "1.0.0",
    "name": "Environment Secrets Scan",
    "description": "Scan environment variables for potential leaked secrets (API keys, tokens, passwords)",
    "tags": [
        "guardian",
        "custodian",
        "security",
        "secrets"
    ],
    "governance": {
        "min_policy_tier": "tier1_autonomous",
        "required_approvals": [],
        "covenant_rules": [
            "no_secret_exposure"
        ]
    },
    "executor": "guardian",
    "interval_ms": 600000,
    "workflow": {
        "steps": [
            {
                "id": "load-patterns",
                "name": "Load secret patterns",
                "tools": [],
                "action": "Load secret detection regex patterns (api_key, secret_key, access_token, auth_token, private_key)",
                "transitions": {
                    "success": "scan-env",
                    "failed": "report-error"
                }
            },
            {
                "id": "scan-env",
                "name": "Scan environment variables",
                "tools": [],
                "action": "Scan all environment variables for secret patterns",
                "transitions": {
                    "success": "analyze",
                    "failed": "report-error"
                }
            },
            {
                "id": "analyze",
                "name": "Analyze findings",
                "tools": [],
                "action": "Identify PRISM_* variables with suspicious values",
                "transitions": {
                    "success": "report",
                    "failed": "report-error"
                }
            }
        ]
    }
}