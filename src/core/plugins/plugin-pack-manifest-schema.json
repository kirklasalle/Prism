{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PRISM Plugin Pack Manifest Schema",
    "description": "Schema defining the structure and validation rules for PRISM adapter/plugin packages",
    "type": "object",
    "required": [
        "manifest_version",
        "pack_name",
        "pack_version",
        "description",
        "author",
        "license",
        "adapters",
        "compatibility"
    ],
    "properties": {
        "manifest_version": {
            "type": "string",
            "pattern": "^1\\.0$",
            "description": "Manifest schema version (must be 1.0)"
        },
        "pack_name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "minLength": 1,
            "maxLength": 128,
            "description": "Unique identifier for the plugin pack"
        },
        "pack_version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
            "description": "Semantic version of the plugin pack (SemVer 2.0.0)"
        },
        "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500,
            "description": "Human-readable description of the plugin pack"
        },
        "author": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                },
                "email": {
                    "type": "string",
                    "format": "email"
                },
                "url": {
                    "type": "string",
                    "format": "uri"
                }
            },
            "description": "Author contact information"
        },
        "license": {
            "type": "string",
            "enum": [
                "Apache-2.0",
                "MIT",
                "GPL-3.0",
                "BSD-2-Clause",
                "BSD-3-Clause",
                "ISC",
                "Unlicense",
                "PRISM-EE",
                "PRISM-Community"
            ],
            "description": "SPDX license identifier"
        },
        "repository": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "git",
                        "hg",
                        "svn"
                    ]
                },
                "url": {
                    "type": "string"
                }
            }
        },
        "adapters": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "adapter_id",
                    "adapter_type",
                    "entry_file",
                    "capabilities",
                    "tier_routing"
                ],
                "properties": {
                    "adapter_id": {
                        "type": "string",
                        "pattern": "^[a-z0-9-]+$",
                        "minLength": 1,
                        "maxLength": 64
                    },
                    "adapter_type": {
                        "type": "string",
                        "enum": [
                            "terminal",
                            "container",
                            "protocol",
                            "system",
                            "application",
                            "custom"
                        ],
                        "description": "Adapter category"
                    },
                    "entry_file": {
                        "type": "string",
                        "description": "Path to compiled adapter entry point (relative to pack root)"
                    },
                    "description": {
                        "type": "string",
                        "maxLength": 300
                    },
                    "version": {
                        "type": "string",
                        "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)"
                    },
                    "capabilities": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "string",
                            "pattern": "^[a-z0-9_]+$"
                        },
                        "description": "List of capabilities provided (e.g., 'execute_command', 'snapshot_container')"
                    },
                    "tier_routing": {
                        "type": "object",
                        "description": "Tier assignment rules for operations",
                        "properties": {
                            "tier1_keywords": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "tier2_keywords": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "tier3_keywords": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "default_tier": {
                                "type": "integer",
                                "enum": [
                                    1,
                                    2,
                                    3
                                ],
                                "default": 2
                            }
                        }
                    },
                    "dependencies": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "adapter_id": {
                                    "type": "string"
                                },
                                "min_version": {
                                    "type": "string"
                                },
                                "max_version": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "trust_level": {
                        "type": "string",
                        "enum": [
                            "untrusted",
                            "community",
                            "verified",
                            "official"
                        ],
                        "default": "untrusted",
                        "description": "Trust classification for business profile install gating"
                    }
                }
            },
            "description": "List of adapters included in this pack"
        },
        "compatibility": {
            "type": "object",
            "required": [
                "prism_min_version",
                "profiles"
            ],
            "properties": {
                "prism_min_version": {
                    "type": "string",
                    "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)",
                    "description": "Minimum PRISM runtime version required"
                },
                "prism_max_version": {
                    "type": "string",
                    "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)"
                },
                "profiles": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "individual",
                            "business",
                            "both"
                        ]
                    },
                    "minItems": 1,
                    "description": "Supported execution profiles"
                },
                "node_version": {
                    "type": "string",
                    "description": "Node.js version requirement (e.g., '>=18.0.0')"
                },
                "os": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "linux",
                            "macos",
                            "windows",
                            "any"
                        ]
                    },
                    "description": "Supported operating systems"
                }
            }
        },
        "install_requirements": {
            "type": "object",
            "properties": {
                "permissions_required": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of system permissions needed (e.g., 'docker', 'sudo')"
                },
                "environment_vars": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "required": {
                                "type": "boolean"
                            },
                            "description": {
                                "type": "string"
                            }
                        }
                    }
                },
                "disk_space_mb": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Minimum disk space required in MB"
                }
            }
        },
        "security": {
            "type": "object",
            "properties": {
                "review_status": {
                    "type": "string",
                    "enum": [
                        "unreviewed",
                        "community-reviewed",
                        "security-reviewed"
                    ],
                    "default": "unreviewed"
                },
                "signature": {
                    "type": "string",
                    "description": "Optional PGP/asymmetric signature for business profile verification"
                },
                "signature_algorithm": {
                    "type": "string",
                    "enum": [
                        "rsa-2048",
                        "rsa-4096",
                        "ecdsa-256",
                        "ecdsa-384"
                    ]
                },
                "known_issues": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "severity": {
                                "type": "string",
                                "enum": [
                                    "low",
                                    "medium",
                                    "high",
                                    "critical"
                                ]
                            },
                            "description": {
                                "type": "string"
                            },
                            "mitigated": {
                                "type": "boolean"
                            }
                        }
                    }
                }
            }
        },
        "metadata": {
            "type": "object",
            "properties": {
                "tags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "released": {
                    "type": "string",
                    "format": "date-time"
                },
                "deprecated": {
                    "type": "boolean",
                    "default": false
                },
                "replacement_pack": {
                    "type": "string",
                    "description": "If deprecated, which pack replaces this one"
                }
            }
        }
    },
    "additionalProperties": false
}